// This is your Prisma schema file.
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserSystemRole {
  USER
  ADMIN
}

enum WeddingRole {
  BRIDE
  GROOM
}

enum DiagnosisExperience {
  EXPERIENCED      // 기존 진단 경험 있음
  NOT_EXPERIENCED  // 진단 경험 없음
  UNSURE           // 잘 모르겠음
}

enum PersonalColorSeason {
  SPRING_WARM
  SUMMER_COOL
  AUTUMN_WARM
  WINTER_COOL
}

enum SkeletonType {
  STRAIGHT
  WAVE
  NATURAL
}

enum DiagnosisStatus {
  PENDING      // 대기 중
  IN_PROGRESS  // 진단 중
  COMPLETED    // 완료
  FAILED       // 실패
  MANUAL       // 수동 입력 전환
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String?        @map("password_hash")
  name         String
  systemRole   UserSystemRole @default(USER) @map("system_role")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  deletedAt    DateTime?      @map("deleted_at")

  profile      Profile?
  sessions     UserSession[]

  @@index([email])
  @@map("users")
}

// ─── UserSession ─────────────────────────────────────────────────────────────

model UserSession {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("user_sessions")
}

// ─── Profile ─────────────────────────────────────────────────────────────────

model Profile {
  id                  String               @id @default(cuid())
  userId              String               @unique @map("user_id")
  weddingRole         WeddingRole?         @map("wedding_role")
  diagnosisExperience DiagnosisExperience? @map("diagnosis_experience")
  personalColorSeason PersonalColorSeason? @map("personal_color_season")
  skeletonType        SkeletonType?        @map("skeleton_type")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  diagnosisGate       DiagnosisGate?
  diagnosisLogs       DiagnosisLog[]

  @@map("profiles")
}

// ─── DiagnosisGate ───────────────────────────────────────────────────────────

model DiagnosisGate {
  id           String              @id @default(cuid())
  profileId    String              @unique @map("profile_id")
  experience   DiagnosisExperience
  weddingRole  WeddingRole         @map("wedding_role")
  nextRoute    String              @map("next_route")
  completedAt  DateTime?           @map("completed_at")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  profile      Profile             @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("diagnosis_gates")
}

// ─── DiagnosisLog ────────────────────────────────────────────────────────────
// 진단 시도 이력 (재촬영, 수동 전환 등 C정책 추적용)

model DiagnosisLog {
  id               String          @id @default(cuid())
  profileId        String          @map("profile_id")
  diagnosisType    String          @map("diagnosis_type") // "personal_color" | "skeleton"
  status           DiagnosisStatus
  confidence       Float?
  retryCount       Int             @default(0) @map("retry_count")
  isManualFallback Boolean         @default(false) @map("is_manual_fallback")
  errorMessage     String?         @map("error_message") @db.Text
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  profile          Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([diagnosisType])
  @@map("diagnosis_logs")
}
