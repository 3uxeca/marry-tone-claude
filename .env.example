# MarryTone 로컬 개발 환경 변수
# cp .env.example .env.local 후 값 수정

# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=mysql://marryapp:marryapp_password@localhost:3306/marryapp_db

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── API ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
ML_SIDECAR_URL=http://localhost:8000

# ─── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=dev_jwt_secret_change_in_production_32chars
JWT_EXPIRES_IN=7d

# ─── Frontend ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api
